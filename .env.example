# Environment Variables
# Copy this file to .env.local for local development
# .env.local is gitignored — never commit secrets

# Public variables (exposed to the browser, prefix with NEXT_PUBLIC_)
# NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# Server-only variables (never exposed to the browser)
# DATABASE_URL=
# API_SECRET_KEY=

# Vercel automatically injects these in deployed environments:
# VERCEL=1
# VERCEL_ENV=production|preview|development
# VERCEL_URL=<deployment-url>
# VERCEL_BRANCH_URL=<branch-url>
# VERCEL_PROJECT_PRODUCTION_URL=<production-url>
